{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "ESNext",
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
